# App
APP_NAME=Support Ticket Backend
APP_VERSION=0.1.0
DEBUG=True

# Database
DATABASE_URL=sqlite:///./data/tickets.db

# CORS
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# AI
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
AI_REQUEST_TIMEOUT_SECONDS=30
MOCK_AI_MODE=true
USE_MOCK_AI=true
